"line":16,"column":1},"end":{"line":16,"column":1}},"key":"lwo6P9pNQB"}],"key":"n27NXG8063"},{"type":"text","value":" — has to be met by something else: coal or gas plants domestically,\nor imports (nuclear power from a neighboring country, for instance).","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"key":"vNwNzeECO5"}],"key":"rSsWQIAwlV"},{"type":"paragraph","position":{"start":{"line":24,"column":1},"end":{"line":27,"column":1}},"children":[{"type":"text","value":"Residual load is, by definition, just demand minus renewable generation. So\nif we can forecast renewable generation well, we get residual load for free\n— which is arguably the more economically interesting quantity, since it’s\nresidual load that drives prices, dispatch, and import/export flows.","position":{"start":{"line":24,"column":1},"end":{"line":24,"column":1}},"key":"pNa4wTnpLn"}],"key":"Kg0sKp5lq0"},{"type":"heading","depth":3,"position":{"start":{"line":29,"column":1},"end":{"line":29,"column":1}},"children":[{"type":"text","value":"Why it’s hard in practice","position":{"start":{"line":29,"column":1},"end":{"line":29,"column":1}},"key":"H1LBmGXpZ3"}],"identifier":"why-its-hard-in-practice","label":"Why it’s hard in practice","html_id":"why-its-hard-in-practice","implicit":true,"key":"V0hWbPxMtR"},{"type":"paragraph","position":{"start":{"line":31,"column":1},"end":{"line":33,"column":1}},"children":[{"type":"text","value":"Even where the physical equations themselves are well understood (wind is\nthe clearest example), several things stand between “we know the weather”\nand “we know the exact power injected into the grid”:","position":{"start":{"line":31,"column":1},"end":{"line":31,"column":1}},"key":"gkHgZYJBQQ"}],"key":"hWGnRbsT4f"},{"type":"list","ordered":true,"start":1,"spread":false,"position":{"start":{"line":35,"column":1},"end":{"line":72,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":35,"column":1},"end":{"line":3